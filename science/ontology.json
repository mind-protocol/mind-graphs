    "scientific_assertions": ["estimate", "claim"],
    "source_objects": ["source_document", "evidence"]
  },
  "relationConstraints": {
    "DESCRIBES": { "sourceTypes": ["source_document"], "targetTypes": ["study"] },
    "IN_CONTEXT": { "sourceTypes": ["study", "observation", "estimate", "claim"], "targetTypes": ["context"] },
    "INVESTIGATES": { "sourceTypes": ["study"], "targetTypes": ["variable"] },
    "PROPOSES": { "sourceTypes": ["study"], "targetTypes": ["mechanism"] },
    "REPORTS_OBSERVATION": { "sourceTypes": ["study"], "targetTypes": ["observation"] },
    "REPORTS_ESTIMATE": { "sourceTypes": ["study"], "targetTypes": ["estimate"] },
    "DERIVED_FROM": { "sourceTypes": ["estimate"], "targetTypes": ["observation"] },
    "SUPPORTS_CLAIM": { "sourceTypes": ["estimate"], "targetTypes": ["claim"] },
    "JUSTIFIED_BY": { "sourceTypes": ["claim"], "targetTypes": ["evidence"] },
    "LOCATED_IN": { "sourceTypes": ["evidence"], "targetTypes": ["source_document"] },
    "ABOUT": { "sourceTypes": ["claim", "estimate", "observation"], "targetTypes": ["variable", "mechanism", "context", "intervention"] },
    "RELATES": { "sourceTypes": ["mechanism"], "targetTypes": ["variable", "observation"] }
  },
  "quantification": {
    "probabilityPct": { "definition": "Probabilité rapportée en pourcentage.", "requires": ["supportingNodes"] },
    "confidenceScore": { "definition": "Certitude calculée, jamais inventée à l'ingestion.", "requires": ["supportingNodes"] },
    "effectSizePct": { "definition": "Effet relatif rapporté en pourcentage.", "requires": ["supportingNodes"] }
  },
  "hierarchy": { "kinds": ["none", "part_of", "subcase_of"] },
  "nodeTypeHierarchy": {},
  "traversal": {
    "familyDefaults": { "provenance": 0.95, "study_structure": 0.85, "justification": 0.9, "causal_structure": 0.75 }
  }
